mixin menu(navigationMenu, colorTheme="light", colorBurger="white_menu")
    .navigation.flex_between.items_center.wrapper
        .logo.flex_between.items_center
            a(href="index.html").flex.items_center
                picture 
                    img(src="assets/images/logo.svg" alt="logo.misocial")
                span(class=colorTheme) misocial  
        nav.flex_nav.flex.full_menu
            ul#popup.popup.flex_between.items_center.d-block(class=colorTheme)
                for item in navigationMenu 
                    li 
                        a.menu(href=item[1])  #{item[0]} 
                a#cancel_popup.cancel_popup(href="") 

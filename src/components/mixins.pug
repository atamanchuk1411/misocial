-
    let navigationMenu = [
        ["Home", "index.html"],
        ["Why MISOCIAL", "#"],
        ["Features", "#"],
        ["Articles", "#"],
        ["Pricing", "#"],
    ]

mixin menu(navigationMenu, colorTheme="light")
    .navigation.flex_between.items_center
        .logo 
            a(href="index.html")
                picture 
                    img(src="assets/images/logo.svg" alt="logo.misocial")
                span(class=colorTheme) misocial 
            nav.flex_nav 
                ul.flex_between.items_center(class=colorTheme)
                    for item in navigationMenu 
                        li 
                            a(href=item[1])  #{item[0]} 
                p(class=colorTheme).cta_empty
                    a(href="#" class="btn") get started


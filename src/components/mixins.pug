mixin card(oneCard)
    figure.card 
        figcaption 
            picture 
                img(src=oneCard.img, alt=oneCard.alt)
            p.personal #{oneCard.personal}
            p.price 
                span.currency #{oneCard.currency}
                b #{oneCard.price}
                if oneCard.isMonth 
                    | /month
                else 
                    | /year
            ul.description 
                for item in oneCard.description 
                    li #{item}
            a(href=oneCard.href) #{oneCard.btnText}

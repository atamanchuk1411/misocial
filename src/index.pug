doctype html
html(lang="uk")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, user-scalable=yes, initial-scale=0.1, maximum-scale=2.0, minimum-scale=1.0")
        link(rel="stylesheet" href="assets/styles/style.sass")
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Maven+Pro:wght@400..900&display=swap" rel="stylesheet")
        link(rel="icon" type="image/svg" href="assets/images/logo.svg")
        title Misocial | Space Exploration
    body 
        include components/mixins 
        div#black.black
        header 
            +menu(navigationMenu)
            div.main.container.wrapper.flex_center
                p.light.marketing.miso SOCIAL MARKETING & ANALYTICS
                    span.start.linew 
                    span.end.linew
                h1.light.big Pricing Table
                p.light.w33.small Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut.
                a.arrowDown(href="#scrool") 
                    span.circle 
                    img.arrow(src="assets/images/arrowDown.svg", alt="")
        main 
            section.background
                div.column.flex_center
                    p.grey.marketing.miso MISOCIAL
                        span.start.lineg
                        span.end.lineg
                    h2 Select a Plan 
                    p.small.grey.w40 Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut.
                .grid.col_3#scrool
                    +card(cardsInfo.satelite)
                    +card(cardsInfo.machine)
                    +card(cardsInfo.rocket)
            section.map.items_center.flex_center
                p.light.marketing SOCIAL MARKETING & ANALYTICS
                h2.light Take control of your data
                div.buttons
                    a.get(href="#") get started
                    a.exp(href="#") explore features
        footer 
            +menu(navigationMenu, "dark", "black_menu")
            nav.wrapper.flex_between

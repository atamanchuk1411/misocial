mixin card(oneCard)
    figure.card
        figcaption
            picture.flex_center 
                img(src=oneCard.img, alt=oneCard.alt)
            p.personal.text_center.grey.marketing #{oneCard.personal}
            p.price.text_center
                span.currency #{oneCard.currency}
                b.s60 #{oneCard.price}
                if oneCard.isMonth 
                    | /month
                else 
                    | /year
            ul.description.text_center
                for item in oneCard.description 
                    li.smal.grey #{item}
            a.button.btn_fixed(href=oneCard.href) #{oneCard.btnText}
